@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container pb-5">
        <div class="row">
            <div class="col-12 mb-4">
                <h3 class="fw-bold text-dark">Hesap Ayarları</h3>
                <p class="text-muted">Profil bilgilerinizi, iletişiminizi ve güvenliğinizi yönetin.</p>
            </div>

            <div class="col-lg-3 mb-4">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-body p-3">
                        <div class="list-group settings-nav" id="list-tab" role="tablist">
                            <a class="list-group-item list-group-item-action active d-flex align-items-center gap-3" 
                               id="list-profile-list" data-bs-toggle="list" href="#list-profile" role="tab">
                                <i class="bi bi-person-circle fs-5"></i> Profil Bilgileri
                            </a>
                            <a class="list-group-item list-group-item-action d-flex align-items-center gap-3" 
                               id="list-contact-list" data-bs-toggle="list" href="#list-contact" role="tab">
                                <i class="bi bi-geo-alt-fill fs-5 text-success"></i> İletişim & Adres
                            </a>
                            <a class="list-group-item list-group-item-action d-flex align-items-center gap-3" 
                               id="list-social-list" data-bs-toggle="list" href="#list-social" role="tab">
                                <i class="bi bi-share-fill fs-5 text-primary"></i> Sosyal Medya
                            </a>
                            <a class="list-group-item list-group-item-action d-flex align-items-center gap-3" 
                               id="list-security-list" data-bs-toggle="list" href="#list-security" role="tab">
                                <i class="bi bi-shield-lock-fill fs-5 text-danger"></i> Şifre & Güvenlik
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-9">
                <div class="tab-content" id="nav-tabContent">
                    
                    <div class="tab-pane fade show active" id="list-profile" role="tabpanel">
                        <div class="card shadow-sm border-0 rounded-4">
                            <div class="card-body p-4">
                                <h5 class="mb-4 fw-bold">Profil Bilgileri</h5>
                                
                                <div class="d-flex align-items-center mb-4 pb-4 border-bottom">
                                    <img src="https://ui-avatars.com/api/?name=Mehmet+Y&background=0d6efd&color=fff&size=128" 
                                         class="rounded-circle profile-header-img" alt="Profil">
                                    <div class="ms-3">
                                        <h6 class="fw-bold mb-1">Profil Fotoğrafı</h6>
                                        <p class="text-muted small mb-2">PNG veya JPG, max 2MB.</p>
                                        <button class="btn btn-sm btn-outline-primary">Fotoğraf Yükle</button>
                                        <button class="btn btn-sm btn-light text-danger">Kaldır</button>
                                    </div>
                                </div>

                                <form>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label small fw-bold text-muted">Ad</label>
                                            <input type="text" class="form-control" value="Mehmet">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label small fw-bold text-muted">Soyad</label>
                                            <input type="text" class="form-control" value="Yılmaz">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label small fw-bold text-muted">Kullanıcı Adı</label>
                                            <div class="input-group">
                                                <span class="input-group-text text-muted">!!!!!</span>
                                                <input type="text" class="form-control" value="mehmetyilmaz">
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label small fw-bold text-muted">E-posta</label>
                                            <input type="email" class="form-control" value="mehmet@ornek.com">
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label small fw-bold text-muted">Biyografi</label>
                                            <textarea class="form-control" rows="3">Full Stack Developer olarak çalışıyorum...</textarea>
                                        </div>
                                        <div class="col-12 text-end mt-3">
                                            <button type="submit" class="btn btn-primary">Kaydet</button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="list-contact" role="tabpanel">
                        <div class="card shadow-sm border-0 rounded-4">
                            <div class="card-body p-4">
                                <h5 class="mb-4 fw-bold text-success"><i class="bi bi-geo-alt me-2"></i>İletişim Bilgileri</h5>
                                <form>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label small fw-bold text-muted">Telefon Numarası</label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                                <input type="tel" class="form-control" placeholder="+90 555 123 45 67">
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label small fw-bold text-muted">Web Sitesi</label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="bi bi-globe"></i></span>
                                                <input type="text" class="form-control" placeholder="www.siteniz.com">
                                            </div>
                                        </div>
                                        
                                        <div class="col-12 mt-4">
                                            <h6 class="fw-bold border-bottom pb-2 mb-3">Adres Detayları</h6>
                                        </div>

                                        <div class="col-12">
                                            <label class="form-label small fw-bold text-muted">Açık Adres</label>
                                            <textarea class="form-control" rows="2" placeholder="Mahalle, Cadde, Sokak, No..."></textarea>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label small fw-bold text-muted">Ülke</label>
                                            <select class="form-select">
                                                <option selected>Türkiye</option>
                                                <option>ABD</option>
                                                <option>Almanya</option>
                                            </select>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label small fw-bold text-muted">Şehir</label>
                                            <input type="text" class="form-control" placeholder="İstanbul">
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label small fw-bold text-muted">Posta Kodu</label>
                                            <input type="text" class="form-control" placeholder="34000">
                                        </div>

                                        <div class="col-12 text-end mt-4">
                                            <button type="submit" class="btn btn-success px-4">İletişim Bilgilerini Güncelle</button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="list-social" role="tabpanel">
                        <div class="card shadow-sm border-0 rounded-4">
                            <div class="card-body p-4">
                                <h5 class="mb-4 fw-bold text-primary">Sosyal Medya Hesapları</h5>
                                <form>
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold text-muted">Facebook</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light text-primary"><i class="bi bi-facebook"></i></span>
                                            <input type="text" class="form-control" placeholder="Kullanıcı adı veya link">
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold text-muted">Instagram</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light text-danger"><i class="bi bi-instagram"></i></span>
                                            <input type="text" class="form-control" placeholder="Kullanıcı adı">
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold text-muted">LinkedIn</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light text-primary"><i class="bi bi-linkedin"></i></span>
                                            <input type="text" class="form-control" placeholder="Profil linki">
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold text-muted">GitHub</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light text-dark"><i class="bi bi-github"></i></span>
                                            <input type="text" class="form-control" placeholder="Kullanıcı adı">
                                        </div>
                                    </div>
                                    <div class="text-end mt-4">
                                        <button type="submit" class="btn btn-primary px-4">Kaydet</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="list-security" role="tabpanel">
                        <div class="card shadow-sm border-0 rounded-4">
                            <div class="card-body p-4">
                                <h5 class="mb-4 fw-bold text-danger">Güvenlik Ayarları</h5>
                                <form>
                                    <div class="mb-4">
                                        <label class="form-label small fw-bold text-muted">Mevcut Şifre</label>
                                        <input type="password" class="form-control">
                                    </div>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label small fw-bold text-muted">Yeni Şifre</label>
                                            <input type="password" class="form-control">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label small fw-bold text-muted">Yeni Şifre (Tekrar)</label>
                                            <input type="password" class="form-control">
                                        </div>
                                    </div>
                                    
                                    <div class="alert alert-light border mt-4">
                                        <div class="d-flex">
                                            <div class="me-3">
                                                <i class="bi bi-shield-check fs-2 text-success"></i>
                                            </div>
                                            <div>
                                                <h6 class="fw-bold mb-1">İki Faktörlü Doğrulama (2FA)</h6>
                                                <p class="text-muted small mb-2">Hesabınızı daha güvenli hale getirmek için 2FA özelliğini açın.</p>
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" id="flexSwitchCheckDefault">
                                                    <label class="form-check-label" for="flexSwitchCheckDefault">Aktifleştir</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="text-end mt-4">
                                        <button type="submit" class="btn btn-danger px-4">Şifreyi Güncelle</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
