@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}



<div class="container py-5">
    <div class="row mb-4">
        <div class="col-12">
            <h3><i class="bi bi-person-gear"></i>Ana sayfa</h3>
            <p class="text-muted">Ana sayfa giriş görseli, kişisel bilgiler ve yeteneklerinizi buradan yönetin.</p>
        </div>
    </div>

    <form asp-controller="Admin" asp-action="UpdateAboutMe" method="post" enctype="multipart/form-data">
        <div class="row">
            <div class="col-lg-4 mb-4">
                <div class="card p-3 h-100">
                    <div class="card-body">
                        <h5 class="card-title mb-4">Görseller & Kişisel Bilgiler</h5>

                        <!-- Kapak Görseli -->
                        <div class="mb-4">
                            <label class="form-label d-flex justify-content-between">
                                <span>Kapak Görseli (Hero)</span>
                                    <span class="badge bg-secondary">Ana Sayfa</span>
                                </label>
                                <div class="hero-preview-box d-flex align-items-center justify-content-center text-white-50"
                                     id="heroPreview"
                                     style="background-image: linear-gradient(rgba(0,0,0,0.6),rgba(0,0,0,0.6)), url('@Url.Content("~/img/hero-img.jpg")');">
                                    <small><i class="bi bi-image"></i> Mevcut Kapak</small>
                                </div>
                                <input type="file" name="heroPhoto" class="form-control form-control-sm mt-2"
                                       id="heroPhoto">
                                <div class="form-text small">Önerilen: 1920x1080px (Koyu tonlar)</div>
                            </div>

                            <!-- Profil Fotoğrafı -->
                            <div class="mb-3 text-center">
                                <img src="~/img/profile-img.jpg" class="rounded mb-2 border" id="profilePreview"
                                     style="width: 100px; height: 100px; object-fit: cover;" alt="Mevcut Foto">
                                    <div class="d-block">
                                        <small class="text-muted">Önerilen boyut: 500x500px</small>
                                    </div>
                                    <input type="file" name="profilePhoto" class="form-control form-control-sm mt-2"
                                           id="profilePhoto">
                                </div>

                                <!-- Ad Soyad -->
                                <div class="mb-3">
                                    <label for="fullName" class="form-label">Ad Soyad</label>
                                    <input type="text" name="FullName" class="form-control" id="fullName"
                                           value="Mehmet Çakmak">
                                </div>

                                <!-- E-mail -->
                                <div class="mb-3">
                                    <label for="email" class="form-label">E-Mail</label>
                                    <input type="email" name="Email" class="form-control" id="email"
                                           placeholder="contact@example.com">
                                </div>
                                <div class="mb-3">
                                    <label for="address" class="form-label">Adres</label>
                                    <input type="address" name="Address" class="form-control" id="address"
                                           placeholder="Mevlana mah.">
                                </div>

                                <!-- Sosyal Medya Kısa Grid -->
                                <div class="mb-3">
                                    <label class="form-label">Sosyal Medya</label>
                                    <div class="d-flex flex-wrap gap-2">
                                        <button type="button" class="btn btn-outline-primary btn-sm" data-bs-toggle="modal"
                                                data-bs-target="#socialModal">
                                            <i class="bi bi-telegram"></i>
                                        </button>
                                        <button type="button" class="btn btn-outline-dark btn-sm" data-bs-toggle="modal"
                                                data-bs-target="#socialModal">
                                            <i class="bi bi-github"></i>
                                        </button>
                                        <button type="button" class="btn btn-outline-info btn-sm" data-bs-toggle="modal"
                                                data-bs-target="#socialModal">
                                            <i class="bi bi-linkedin"></i>
                                        </button>
                                        <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal"
                                                data-bs-target="#socialModal">
                                            <i class="bi bi-instagram"></i>
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary btn-sm"
                                                data-bs-toggle="modal" data-bs-target="#socialModal">
                                            <i class="bi bi-medium"></i>
                                        </button>
                                    </div>
                                    <small class="text-muted d-block mt-1">Düzenlemek için ikonlara tıklayın</small>
                                </div>

                            </div>
                        </div>
                    </div>

                    <div class="col-lg-8">
                        <div class="card mb-4 shadow-sm">
                            <div class="card-header bg-white pb-0">
                                <ul class="nav nav-tabs border-bottom-0" id="langTabs" role="tablist">
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link active" id="tr-tab" data-bs-toggle="tab"
                                                data-bs-target="#tr-content" type="button">🇹🇷 Türkçe</button>
                                    </li>
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link" id="en-tab" data-bs-toggle="tab"
                                                data-bs-target="#en-content" type="button">🇬🇧 English</button>
                                    </li>
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link" id="de-tab" data-bs-toggle="tab"
                                                data-bs-target="#de-content" type="button">🇩🇪 Deutsch</button>
                                    </li>
                                </ul>
                            </div>
                            <div class="card-body pt-0 mt-3">
                                <div class="tab-content" id="langTabsContent">
                                    <div class="tab-pane fade show active" id="tr-content">
                                        <div class="mb-3">
                                            <label for="jobTitle" class="form-label">Profil / Ünvan</label>
                                            <input type="text" name="Title.Tr" class="form-control" id="jobTitle" value="Yazılım Mühendisi">
                                        </div>
                                        <div class="mb-3">
                                            <textarea class="form-control" rows="6" name= "Biography.Tr"
                                                      placeholder="Kendinizden Türkçe bahsedin..."></textarea>
                                        </div>
                                    </div>
                                    <div class="tab-pane fade" id="en-content">
                                        <div class="mb-3">
                                            <label for="jobTitle" class="form-label">Profil / Ünvan</label>
                                            <input type="text" name="Title.En" class="form-control" id="jobTitle" value="Yazılım Mühendisi">
                                        </div>
                                        <div class="mb-3">
                                            <textarea class="form-control" rows="6" name= "Biography.En"
                                                      placeholder="Describe yourself in English..."></textarea>
                                        </div>
                                    </div>
                                    <div class="tab-pane fade" id="de-content">
                                        <div class="mb-3">
                                            <label for="jobTitle" class="form-label">Profil / Ünvan</label>
                                            <input type="text" name="Title.De" class="form-control" id="jobTitle" value="Yazılım Mühendisi">
                                        </div>
                                        <div class="mb-3">
                                            <textarea class="form-control" rows="6" name= "Biography.De"
                                                      placeholder="Beschreiben Sie sich auf Deutsch..."></textarea>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card shadow-sm">
                            <div class="card-body" id="skillsContainer">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h5 class="card-title m-0"><i class="bi bi-code-slash"></i> Beceriler & Yetenekler</h5>
                                    <button type="button" id="addSkillBtn" class="btn btn-sm btn-success"><i
                                        class="bi bi-plus-lg"></i> Yeni Ekle</button>
                                    </div>

                                    <div class="skill-row d-flex align-items-center gap-3 mt-2">
                                        <div class="flex-grow-1">
                                            <input type="text" class="form-control form-control-sm fw-bold"
                                                   placeholder="Yeni Yetenek" value="">
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="d-flex align-items-center gap-2">
                                                <input type="range" class="skill-range form-range" min="0" max="100" value="50">
                                                <span class="skill-val badge bg-primary rounded-pill"
                                                      style="width: 50px;">50%</span>
                                            </div>
                                        </div>
                                        <div class="align-self-end pb-1">
                                            <button type="button" class="btn btn-sm btn-outline-danger border-0 delete-btn">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="skill-row d-flex align-items-center gap-3 mt-2">
                                        <div class="flex-grow-1">
                                            <input type="text" class="form-control form-control-sm fw-bold"
                                                   placeholder="Yeni Yetenek" value="">
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="d-flex align-items-center gap-2">
                                                <input type="range" class="skill-range form-range" min="0" max="100" value="50">
                                                <span class="skill-val badge bg-primary rounded-pill"
                                                      style="width: 50px;">50%</span>
                                            </div>
                                        </div>
                                        <div class="align-self-end pb-1">
                                            <button type="button" class="btn btn-sm btn-outline-danger border-0 delete-btn">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="skill-row d-flex align-items-center gap-3 mt-2">
                                        <div class="flex-grow-1">
                                            <input type="text" class="form-control form-control-sm fw-bold"
                                                   placeholder="Yeni Yetenek" value="">
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="d-flex align-items-center gap-2">
                                                <input type="range" class="skill-range form-range" min="0" max="100" value="50">
                                                <span class="skill-val badge bg-primary rounded-pill"
                                                      style="width: 50px;">50%</span>
                                            </div>
                                        </div>
                                        <div class="align-self-end pb-1">
                                            <button type="button" class="btn btn-sm btn-outline-danger border-0 delete-btn">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </div>
                                    </div>

                                </div>
                            </div>

                            <div class="d-grid gap-2 mt-4">

                                <button type="submit" class="btn btn-primary btn-lg"><i class="bi"></i> Tüm
                                    Değişiklikleri Kaydet</button>
                                </div>
                            </div>
                        </div>
                                @await Html.PartialAsync("../Shared/Modals/Admin/_SocialMediaLinksEditModal.cshtml")
                    </form>
                </div>
    </div>
</div>


            
            @section Scripts {
                <script src="~/js/Admin/index.js"></script>
            }