@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="container py-5">
        <div class="row mb-4 align-items-center">
            <div class="col-md-6">
                <h3><i class="bi bi-briefcase"></i> Projelerim</h3>
                <p class="text-muted">Portfolyonuzdaki projeleri buradan listeleyip yönetebilirsiniz.</p>
            </div>
            <div class="col-md-6 text-md-end">
                <button class="btn btn-primary btn-lg" id="addNewProjectBtn" data-bs-toggle="modal" data-bs-target="#projectModal">
                    <i class="bi bi-plus-lg"></i> Yeni Proje Ekle
                </button>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th scope="col" class="ps-4">Kapak</th>
                                <th scope="col">Proje Başlığı</th>
                                <th scope="col">Kategori</th>
                                <th scope="col">Müşteri (Client)</th>
                                <th scope="col">Tarih</th>
                                <th scope="col" class="text-end pe-4">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody id="projectsTableBody">
                            <tr class="project-row" data-id="1">
                                <td class="ps-4">
                                    <img src="https://via.placeholder.com/100" class="table-img" alt="Proje">
                                </td>
                                <td>
                                    <h6 class="mb-0 fw-bold title-cell">App Development</h6>
                                    <small class="text-muted"><i class="bi bi-link-45deg"></i> example.com</small>
                                </td>
                                <td><span class="badge bg-info bg-opacity-10 text-info px-3">Mobile App</span></td>
                                <td>ASU Company</td>
                                <td>2024-03-01</td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <button type="button" class="btn btn-sm btn-outline-secondary edit-project-btn"><i class="bi bi-pencil"></i></button>
                                        <button type="button" class="btn btn-sm btn-outline-danger delete-btn"><i class="bi bi-trash"></i></button>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
@await Html.PartialAsync("../Shared/Modals/_ProjectModal.cshtml")
@section Scripts{
<script src="~/js/Admin/portfolio.js"></script>
}