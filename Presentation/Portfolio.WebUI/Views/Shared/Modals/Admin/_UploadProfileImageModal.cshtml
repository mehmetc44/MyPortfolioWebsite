<div class="modal fade" id="profileModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Profil Fotoğrafını Düzenle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form asp-controller="File"
                  asp-action="UploadProfilePhoto"
                  method="post"
                  enctype="multipart/form-data">

                @Html.AntiForgeryToken()

                <div class="modal-body text-center">

                    <div class="mb-3">
                        <img src="~/img/profile-img.jpg"
                             id="profileModalPreview"
                             class="img-fluid rounded border shadow"
                             style="width:150px;height:150px;object-fit:cover;">
                    </div>

                    <input type="file"
                           name="profilePhoto"
                           id="profileModalInput"
                           class="form-control form-control-sm"
                           accept="image/*"
                           required>

                </div>

                <div class="modal-footer">
                    <button type="submit" id="saveProfileBtn" class="btn btn-primary w-100">
                        Kaydet
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

