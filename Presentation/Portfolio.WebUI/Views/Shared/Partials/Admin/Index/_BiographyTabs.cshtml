<!-- LANG TABS -->
<div class="card mb-4 shadow-sm">

    <div class="card-header bg-white pb-0">
        <ul class="nav nav-tabs border-bottom-0" id="langTabs">

            <li class="nav-item">
                <button type = "button" class="nav-link active" data-bs-toggle="tab" data-bs-target="#tr-content">
                    🇹🇷 Türkçe
                </button>
            </li>

            <li class="nav-item">
                <button type = "button" class="nav-link" data-bs-toggle="tab" data-bs-target="#en-content">
                    🇬🇧 English
                </button>
            </li>

            <li class="nav-item">
                <button type = "button" class="nav-link" data-bs-toggle="tab" data-bs-target="#de-content">
                    🇩🇪 Deutsch
                </button>
            </li>

        </ul>
    </div>


    <div class="card-body pt-0 mt-3">
        <div class="tab-content">

            <!-- TR -->
            <div class="tab-pane fade show active" id="tr-content">

                <div class="mb-3">
                    <label class="form-label">Profil / Ünvan</label>
                    <input type="text" name="Title.Tr" class="form-control" value="Yazılım Mühendisi">
                </div>

                <div class="mb-3">
                    <textarea class="form-control" rows="6" name="Biography.Tr"
                              placeholder="Kendinizden Türkçe bahsedin..."></textarea>
                </div>

            </div>


            <!-- EN -->
            <div class="tab-pane fade" id="en-content">

                <div class="mb-3">
                    <label class="form-label">Profil / Ünvan</label>
                    <input type="text" name="Title.En" class="form-control" value="Software Engineer">
                </div>

                <div class="mb-3">
                    <textarea class="form-control" rows="6" name="Biography.En"
                              placeholder="Describe yourself in English..."></textarea>
                </div>

            </div>


            <!-- DE -->
            <div class="tab-pane fade" id="de-content">

                <div class="mb-3">
                    <label class="form-label">Profil / Ünvan</label>
                    <input type="text" name="Title.De" class="form-control" value="Softwareentwickler">
                </div>

                <div class="mb-3">
                    <textarea class="form-control" rows="6" name="Biography.De"
                              placeholder="Beschreiben Sie sich auf Deutsch..."></textarea>
                </div>

            </div>

        </div>
    </div>
</div>